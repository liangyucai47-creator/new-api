# Source-build deployment defaults for ECS 8.160.190.198.
# Copy to deploy/ecs/.env.ecs on the server before running docker compose.

APP_IMAGE=new-api-ecs:latest
APP_CONTAINER_NAME=new-api
APP_PUBLIC_PORT=5041

# IP-first bootstrap:
# - Keep PUBLIC_HOST and SERVER_ADDRESS on the ECS public IP.
# - When you later bind a domain, change PUBLIC_HOST to the domain,
#   change SERVER_ADDRESS to https://<your-domain>, and switch
#   NGINX_TEMPLATE to https.conf.template.
PUBLIC_HOST=8.160.190.198
SERVER_ADDRESS=http://8.160.190.198
NGINX_TEMPLATE=http.conf.template
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443

TZ=Asia/Shanghai
SQLITE_PATH=/data/one-api.db?_busy_timeout=30000
NODE_NAME=ecs-node-1
INTERNAL_MODE=false
ERROR_LOG_ENABLED=true
BATCH_UPDATE_ENABLED=true

# REQUIRED: replace before first startup.
SESSION_SECRET=CHANGE_ME_WITH_A_RANDOM_64_CHAR_SECRET

# Required only when switching to HTTPS with a real domain.
LETSENCRYPT_EMAIL=
